<mujoco model="Skydio X2 scene">
  <include file="x2.xml"/>

  <statistic center="0 0 0.1" extent="0.6" meansize=".05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-20" elevation="-20" ellipsoidinertia="true"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <texture type="2d" name="aruco_tag" file="marker_0.png"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="aruco_material" texture="aruco_tag" texuniform="true" reflectance="0"/>
    
    <!-- Red Gate Markers (0-3) -->
    <texture name="tex_0" type="cube" fileright="marker_0.png"/> <material name="mat_0" texture="tex_0" texuniform="true"/>
    <texture name="tex_1" type="cube" fileright="marker_1.png"/> <material name="mat_1" texture="tex_1" texuniform="true"/>
    <texture name="tex_2" type="cube" fileright="marker_2.png"/> <material name="mat_2" texture="tex_2" texuniform="true"/>
    <texture name="tex_3" type="cube" fileright="marker_3.png"/> <material name="mat_3" texture="tex_3" texuniform="true"/>
    
    <!-- Green Gate Markers (4-7) -->
    <texture name="tex_4" type="cube" fileright="marker_4.png"/> <material name="mat_4" texture="tex_4" texuniform="true"/>
    <texture name="tex_5" type="cube" fileright="marker_5.png"/> <material name="mat_5" texture="tex_5" texuniform="true"/>
    <texture name="tex_6" type="cube" fileright="marker_6.png"/> <material name="mat_6" texture="tex_6" texuniform="true"/>
    <texture name="tex_7" type="cube" fileright="marker_7.png"/> <material name="mat_7" texture="tex_7" texuniform="true"/>
    
    <!-- Blue Gate Markers (8-11) -->
    <texture name="tex_8" type="cube" fileright="marker_8.png"/> <material name="mat_8" texture="tex_8" texuniform="true"/>
    <texture name="tex_9" type="cube" fileright="marker_9.png"/> <material name="mat_9" texture="tex_9" texuniform="true"/>
    <texture name="tex_10" type="cube" fileright="marker_10.png"/> <material name="mat_10" texture="tex_10" texuniform="true"/>
    <texture name="tex_11" type="cube" fileright="marker_11.png"/> <material name="mat_11" texture="tex_11" texuniform="true"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>
    
    <body name="red_gate" pos="-2 0 3"> 
      <geom type="box" pos="0 -0.6 0" size="0.05 0.05 0.6" rgba="1 0 0 1"/>
      <geom type="box" pos="0 0.6 0" size="0.05 0.05 0.6" rgba="1 0 0 1"/>
      <geom type="box" pos="0 0 0.65" size="0.05 0.65 0.05" rgba="1 0 0 1"/>
      <geom type="box" pos="0 0 -0.65" size="0.05 0.65 0.05" rgba="1 0 0 1"/>
      <!-- Markers 0-3 -->
      <geom type="box" material="mat_0" pos="0.01 0.6 0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_1" pos="0.01 -0.6 0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_2" pos="0.01 -0.6 -0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_3" pos="0.01 0.6 -0.65" size=".1 .1 .1"/>
    </body>

    <body name="green_gate" pos="-4 -0.6 3.3"> 
      <geom type="box" pos="0 -0.6 0" size="0.05 0.05 0.6" rgba="0 1 0 1"/>
      <geom type="box" pos="0 0.6 0" size="0.05 0.05 0.6" rgba="0 1 0 1"/>
      <geom type="box" pos="0 0 0.65" size="0.05 0.65 0.05" rgba="0 1 0 1"/>
      <geom type="box" pos="0 0 -0.65" size="0.05 0.65 0.05" rgba="0 1 0 1"/>
      <!-- Markers 4-7 -->
      <geom type="box" material="mat_4" pos="0.01 0.6 0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_5" pos="0.01 -0.6 0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_6" pos="0.01 -0.6 -0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_7" pos="0.01 0.6 -0.65" size=".1 .1 .1"/>
    </body>


    <body name="blue_gate" pos="-6 0.6 2.7"> 
      <geom type="box" pos="0 -0.6 0" size="0.05 0.05 0.6" rgba="0 0 1 1"/>
      <geom type="box" pos="0 0.6 0" size="0.05 0.05 0.6" rgba="0 0 1 1"/>
      <geom type="box" pos="0 0 0.65" size="0.05 0.65 0.05" rgba="0 0 1 1"/>
      <geom type="box" pos="0 0 -0.65" size="0.05 0.65 0.05" rgba="0 0 1 1"/>
      <!-- Markers 8-11 -->
      <geom type="box" material="mat_8" pos="0.01 0.6 0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_9" pos="0.01 -0.6 0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_10" pos="0.01 -0.6 -0.65" size=".1 .1 .1"/>
      <geom type="box" material="mat_11" pos="0.01 0.6 -0.65" size=".1 .1 .1"/>
    </body>

  </worldbody>
</mujoco>
